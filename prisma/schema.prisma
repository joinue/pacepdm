generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// MULTI-TENANCY
// ============================================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          TenantUser[]
  folders        Folder[]
  files          File[]
  lifecycles     Lifecycle[]
  metadataFields MetadataField[]
  ecos           ECO[]
  auditLogs      AuditLog[]
  roles          Role[]

  @@map("tenants")
}

// ============================================================
// USERS & RBAC
// ============================================================

model TenantUser {
  id         String   @id @default(uuid())
  tenantId   String
  authUserId String
  email      String
  fullName   String
  roleId     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role          @relation(fields: [roleId], references: [id])
  fileVersions FileVersion[]
  checkOuts    File[]        @relation("CheckedOutBy")
  approvals    Approval[]
  auditLogs    AuditLog[]

  @@unique([tenantId, authUserId])
  @@unique([tenantId, email])
  @@map("tenant_users")
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  TenantUser[]

  @@unique([tenantId, name])
  @@map("roles")
}

// ============================================================
// FOLDERS
// ============================================================

model Folder {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  parentId  String?
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id])
  children Folder[] @relation("FolderTree")
  files    File[]

  @@unique([tenantId, path])
  @@map("folders")
}

// ============================================================
// FILES & VERSIONING
// ============================================================

model File {
  id              String       @id @default(uuid())
  tenantId        String
  folderId        String
  name            String
  partNumber      String?
  description     String?
  fileType        String
  category        FileCategory @default(DOCUMENT)
  currentVersion  Int          @default(1)
  lifecycleState  String       @default("WIP")
  lifecycleId     String?

  thumbnailKey   String?

  isCheckedOut   Boolean   @default(false)
  checkedOutById String?
  checkedOutAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folder       Folder          @relation(fields: [folderId], references: [id])
  lifecycle    Lifecycle?      @relation(fields: [lifecycleId], references: [id])
  checkedOutBy TenantUser?     @relation("CheckedOutBy", fields: [checkedOutById], references: [id])
  versions     FileVersion[]
  metadata     MetadataValue[]
  references   FileReference[] @relation("SourceFile")
  referencedBy FileReference[] @relation("TargetFile")
  ecoItems     ECOItem[]

  @@unique([tenantId, folderId, name])
  @@map("files")
}

enum FileCategory {
  PART
  ASSEMBLY
  DRAWING
  DOCUMENT
  PURCHASED
  OTHER
}

model FileVersion {
  id           String   @id @default(uuid())
  fileId       String
  version      Int
  storageKey   String
  fileSize     Int
  checksum     String?
  uploadedById String
  comment      String?
  createdAt    DateTime @default(now())

  file       File       @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploadedBy TenantUser @relation(fields: [uploadedById], references: [id])

  @@unique([fileId, version])
  @@map("file_versions")
}

model FileReference {
  id            String @id @default(uuid())
  sourceFileId  String
  targetFileId  String
  referenceType String @default("contains")

  sourceFile File @relation("SourceFile", fields: [sourceFileId], references: [id], onDelete: Cascade)
  targetFile File @relation("TargetFile", fields: [targetFileId], references: [id], onDelete: Cascade)

  @@unique([sourceFileId, targetFileId, referenceType])
  @@map("file_references")
}

// ============================================================
// METADATA (Custom Properties)
// ============================================================

model MetadataField {
  id         String         @id @default(uuid())
  tenantId   String
  name       String
  fieldType  MetadataType   @default(TEXT)
  options    Json?
  isRequired Boolean        @default(false)
  isSystem   Boolean        @default(false)
  sortOrder  Int            @default(0)
  appliesTo  FileCategory[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  values MetadataValue[]

  @@unique([tenantId, name])
  @@map("metadata_fields")
}

enum MetadataType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  URL
}

model MetadataValue {
  id      String @id @default(uuid())
  fileId  String
  fieldId String
  value   String

  file  File          @relation(fields: [fileId], references: [id], onDelete: Cascade)
  field MetadataField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fileId, fieldId])
  @@map("metadata_values")
}

// ============================================================
// LIFECYCLE & WORKFLOW
// ============================================================

model Lifecycle {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  states      LifecycleState[]
  transitions LifecycleTransition[]
  files       File[]

  @@unique([tenantId, name])
  @@map("lifecycles")
}

model LifecycleState {
  id          String  @id @default(uuid())
  lifecycleId String
  name        String
  color       String  @default("#6B7280")
  isInitial   Boolean @default(false)
  isFinal     Boolean @default(false)
  sortOrder   Int     @default(0)

  lifecycle       Lifecycle             @relation(fields: [lifecycleId], references: [id], onDelete: Cascade)
  transitionsFrom LifecycleTransition[] @relation("FromState")
  transitionsTo   LifecycleTransition[] @relation("ToState")

  @@unique([lifecycleId, name])
  @@map("lifecycle_states")
}

model LifecycleTransition {
  id               String  @id @default(uuid())
  lifecycleId      String
  fromStateId      String
  toStateId        String
  name             String
  requiresApproval Boolean @default(false)
  approvalRoles    Json?

  lifecycle Lifecycle      @relation(fields: [lifecycleId], references: [id], onDelete: Cascade)
  fromState LifecycleState @relation("FromState", fields: [fromStateId], references: [id])
  toState   LifecycleState @relation("ToState", fields: [toStateId], references: [id])

  @@map("lifecycle_transitions")
}

// ============================================================
// ENGINEERING CHANGE ORDERS
// ============================================================

model ECO {
  id           String         @id @default(uuid())
  tenantId     String
  ecoNumber    String
  title        String
  description  String?
  status       ECOStatus      @default(DRAFT)
  priority     ECOPriority    @default(MEDIUM)
  reason       ECOReason?
  changeType   ECOChangeType?
  costImpact   ECOCostImpact?
  disposition  ECODisposition?
  effectivity  String?
  createdById  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     ECOItem[]
  approvals Approval[]

  @@unique([tenantId, ecoNumber])
  @@map("ecos")
}

enum ECOStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
  CLOSED
}

enum ECOPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ECOReason {
  DESIGN_IMPROVEMENT
  COST_REDUCTION
  DEFECT_FIX
  REGULATORY
  MANUFACTURING
  CUSTOMER_REQUEST
  OTHER
}

enum ECOChangeType {
  DOCUMENT_ONLY
  COMPONENT
  ASSEMBLY
  PROCESS
}

enum ECOCostImpact {
  NONE
  MINOR
  MODERATE
  SIGNIFICANT
}

enum ECODisposition {
  USE_AS_IS
  REWORK
  SCRAP
  RETURN_TO_VENDOR
  NOT_APPLICABLE
}

model ECOItem {
  id         String @id @default(uuid())
  ecoId      String
  fileId     String
  changeType String
  reason     String?

  eco  ECO  @relation(fields: [ecoId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id])

  @@map("eco_items")
}

model Approval {
  id          String         @id @default(uuid())
  ecoId       String
  approverId  String
  status      ApprovalStatus @default(PENDING)
  comment     String?
  respondedAt DateTime?
  createdAt   DateTime       @default(now())

  eco      ECO        @relation(fields: [ecoId], references: [id], onDelete: Cascade)
  approver TenantUser @relation(fields: [approverId], references: [id])

  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// APPROVAL WORKFLOWS ENGINE (migration-002, migration-006)
// ============================================================

model ApprovalGroup {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members              ApprovalGroupMember[]
  transitionRules      TransitionApprovalRule[]
  approvalDecisions    ApprovalDecision[]
  workflowSteps        ApprovalWorkflowStep[]

  @@unique([tenantId, name])
  @@map("approval_groups")
}

model ApprovalGroupMember {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  createdAt DateTime @default(now())

  group ApprovalGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("approval_group_members")
}

model TransitionApprovalRule {
  id           String  @id @default(uuid())
  transitionId String
  groupId      String
  isRequired   Boolean @default(true)
  sortOrder    Int     @default(0)

  group ApprovalGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([transitionId, groupId])
  @@map("transition_approval_rules")
}

model ApprovalRequest {
  id               String    @id @default(uuid())
  tenantId         String
  type             String // FILE_TRANSITION, ECO
  entityType       String // file, eco
  entityId         String
  transitionId     String?
  requestedById    String
  workflowId       String?
  currentStepOrder Int       @default(1)
  status           String    @default("PENDING") // PENDING, APPROVED, REJECTED, RECALLED, REWORK
  title            String
  description      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?

  workflow  ApprovalWorkflow?  @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  decisions ApprovalDecision[]
  history   ApprovalHistory[]

  @@index([tenantId, status])
  @@map("approval_requests")
}

model ApprovalDecision {
  id             String    @id @default(uuid())
  requestId      String
  groupId        String
  stepId         String?
  deciderId      String?
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED, REWORK, WAITING, RECALLED
  signatureLabel String?
  approvalMode   String?   @default("ANY") // ANY, ALL, MAJORITY
  deadlineAt     DateTime?
  comment        String?
  decidedAt      DateTime?
  createdAt      DateTime  @default(now())

  request ApprovalRequest       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  group   ApprovalGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  step    ApprovalWorkflowStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@map("approval_decisions")
}

model ApprovalWorkflow {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       ApprovalWorkflowStep[]
  assignments ApprovalWorkflowAssignment[]
  requests    ApprovalRequest[]

  @@unique([tenantId, name])
  @@map("approval_workflows")
}

model ApprovalWorkflowStep {
  id             String   @id @default(uuid())
  workflowId     String
  groupId        String
  stepOrder      Int      @default(1)
  approvalMode   String   @default("ANY") // ANY, ALL, MAJORITY
  signatureLabel String   @default("Approved")
  deadlineHours  Int?
  createdAt      DateTime @default(now())

  workflow  ApprovalWorkflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  group     ApprovalGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  decisions ApprovalDecision[]

  @@index([workflowId])
  @@map("approval_workflow_steps")
}

model ApprovalWorkflowAssignment {
  id           String   @id @default(uuid())
  tenantId     String
  workflowId   String
  transitionId String?
  ecoTrigger   String? // SUBMITTED, IN_REVIEW
  createdAt    DateTime @default(now())

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([transitionId])
  @@map("approval_workflow_assignments")
}

model ApprovalHistory {
  id        String   @id @default(uuid())
  requestId String
  event     String // CREATED, STEP_ACTIVATED, APPROVED, REJECTED, RECALLED, REWORK_REQUESTED, RESUBMITTED, COMPLETED, DEADLINE_WARNING
  userId    String?
  details   String?
  createdAt DateTime @default(now())

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("approval_history")
}

// ============================================================
// NOTIFICATIONS (migration-003)
// ============================================================

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  title     String
  message   String
  type      String   @default("system") // approval, transition, checkout, eco, system
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId, userId, isRead])
  @@map("notifications")
}

// ============================================================
// COMMENT MENTIONS (migration-mentions)
// ============================================================

model CommentMention {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  mentionedBy String
  entityType  String // approval_decision, file_version
  entityId    String
  comment     String
  createdAt   DateTime @default(now())

  @@index([tenantId, userId])
  @@index([entityType, entityId])
  @@map("comment_mentions")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   TenantUser? @relation(fields: [userId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
